media = [
    {"title": "Interstellar", "genre": "sci fi", "mood": "sp‰nnande", "age": "13+", "runtime": "2:49"},
    {"title": "War Machine", "genre": "action", "mood": "rolig", "age": "16+", "runtime": "1:49"},
    {"title": "The Equalizer", "genre": "thriller", "mood": "sp‰nnande", "age": "15+", "runtime": "2:12"},
    {"title": "The Conjuring", "genre": "horror", "mood": "l‰skig", "age": "15+", "runtime": "1:52"},
    {"title": "Lord Of The Rings", "genre": "adventure", "mood": "episk", "age": "11+", "runtime": "2:58"},
    {"title": "The Mummy", "genre": "adventure", "mood": "sp‰nnande", "age": "15+", "runtime": "1:50"},
    {"title": "Jack Reacher", "genre": "action", "mood": "sp‰nnande", "age": "15+", "runtime": "2:10"},
    {"title": "2012", "genre": "sci fi", "mood": "sp‰nnande", "age": "11+", "runtime": "2:38"},
    {"title": "Bad Boys Ride Or Die", "genre": "comedy", "mood": "rolig", "age": "15+", "runtime": "1:55"},
    {"title": "Terrifier", "genre": "horror", "mood": "l‰skig", "age": "18+", "runtime": "1:25"}
]

genre = input("What genre do you like? ")
mood = input("What movie mood do you want? ")

best_score = 0
best_movie = ""

for movie in media:
    score = 0

    if movie["genre"] == genre:
        score += 2

    if movie["mood"] == mood:
        score += 1

    if score > best_score:
        best_score = score
        best_movie = movie["title"]

print("We recommend:", best_movie)